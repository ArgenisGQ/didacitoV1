FROM python:3.12-slim

WORKDIR /app

# PYTHONPATH must include django_project so both Django and FastAPI imports work
ENV PYTHONPATH="/app:/app/django_project"

RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN chmod +x entrypoint-fastapi.sh

EXPOSE 8001

ENTRYPOINT ["/app/entrypoint-fastapi.sh"]
